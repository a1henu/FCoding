# HTTP server
HOST=0.0.0.0
PORT=3000
FEISHU_CALLBACK_PATH=/feishu/events
FEISHU_EVENT_MODE=ws
BODY_LIMIT_BYTES=1048576

# Feishu app credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFY_SIGNATURE=false
FEISHU_SEND_ACK=true
FEISHU_BASE_URL=https://open.feishu.cn/open-apis

# Access control. Leave empty only for a trusted private deployment.
ALLOWED_OPEN_IDS=
ALLOWED_USER_IDS=
ALLOWED_CHAT_IDS=
BOT_TRIGGER_PREFIX=codex

# Codex execution
CODEX_COMMAND=codex
CODEX_ARGS=exec --skip-git-repo-check --sandbox workspace-write
CODEX_WORKDIR=/path/to/repo
CODEX_TIMEOUT_MS=600000
CODEX_PROGRESS_INTERVAL_MS=30000
CODEX_MAX_OUTPUT_CHARS=12000

# Optional API-mode runtime defaults. Put real API keys in ignored .env.api.
FCODING_AUTH_MODE=chatgpt
FCODING_MODEL=
FCODING_API_BASE_URL=https://api.openai.com/v1
FCODING_API_KEY_ENV_VAR=OPENAI_API_KEY
